# Backend Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/misinformation_db?retryWrites=true&w=majority
GOOGLE_FACT_CHECK_KEY=your_google_api_key_here

# Frontend/Backend URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Optional Services
REDIS_URL=redis://localhost:6379
NEWS_API_KEY=your_news_api_key_here

# Application Settings
LOG_LEVEL=INFO
MAX_WORKERS=4
CACHE_ENABLED=true

# Model Configuration
MODELS_CACHE_DIR=./ml-models/cache

# Database Settings
MONGODB_DB_NAME=misinformation_db

